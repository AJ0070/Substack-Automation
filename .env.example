GEMINI_API_KEY=your_google_ai_studio_api_key
SUBSTACK_EMAIL=you@example.com
SUBSTACK_PASSWORD=your_substack_password
PUBLISH_MODE=draft

# Optional
SUBSTACK_PUBLICATION_URL=https://your-publication.substack.com
SUBSTACK_AUTH_STATE_PATH=substack-auth-state.json
HEADLESS=true
ARTICLE_DIR=articles
LOG_DIR=logs
MAX_RETRIES=6
GEMINI_RETRY_INITIAL_DELAY_SECONDS=10
GEMINI_RETRY_MAX_DELAY_SECONDS=90
GENERATION_MODE=compact
PLAYWRIGHT_TIMEOUT_MS=45000
